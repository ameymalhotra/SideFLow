{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "types": ["chrome", "node"],
    "baseUrl": ".",
    "paths": { "~/*": ["./src/*"] }
  },
  "include": ["src/**/*.ts", ".wxt/**/*.d.ts"]
}
